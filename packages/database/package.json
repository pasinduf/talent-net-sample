{
  "name": "@talent-net/database",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "db:migrate": "ts-node -r tsconfig-paths/register ./src/cli/migrate.ts run",
    "db:migrate:revert": "ts-node -r tsconfig-paths/register ./src/cli/migrate.ts revert",
    "db:generate": "ts-node -r tsconfig-paths/register ./src/cli/migrate.ts generate",
    "db:seed": "ts-node -r tsconfig-paths/register ./src/cli/seed.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "typeorm": "^0.3.20",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@talent-net/config": "*",
    "@types/pg": "^8.11.0",
    "dotenv": "^16.4.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.0"
  }
}
